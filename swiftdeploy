AUDIT_FILE      = os.path.join(BASE_DIR, "audit_report.md")

# ── colours ────────────────────────────────────────────────────
def green(msg):  return f"\033[92m{msg}\033[0m"
def red(msg):    return f"\033[91m{msg}\033[0m"
def yellow(msg): return f"\033[93m{msg}\033[0m"
def bold(msg):   return f"\033[1m{msg}\033[0m"
def cyan(msg):   return f"\033[96m{msg}\033[0m"

def ok(msg):   print(f"  {green('✔')}  {msg}")
def fail(msg): print(f"  {red('✘')}  {msg}")
def info(msg): print(f"  {yellow('→')}  {msg}")

# ── manifest ───────────────────────────────────────────────────
def load_manifest():
    if not os.path.exists(MANIFEST_PATH):
        print(red("[ERROR] manifest.yaml not found."))
        sys.exit(1)
    with open(MANIFEST_PATH) as f:
        data = yaml.safe_load(f)
    if not isinstance(data, dict):
        print(red("[ERROR] manifest.yaml is empty or not valid YAML."))
        sys.exit(1)
    return data

def build_vars(manifest):
    svc   = manifest.get("services", {})
    nginx = manifest.get("nginx",    {})
    opa   = manifest.get("opa",      {})
    net   = manifest.get("network",  {})
    return {
        "SERVICE_IMAGE":   svc.get("image",          "swift-deploy-1-node:latest"),
        "SERVICE_PORT":    str(svc.get("port",        3000)),
        "MODE":            svc.get("mode",            "stable"),
        "APP_VERSION":     svc.get("app_version",     "1.0.0"),
        "RESTART_POLICY":  svc.get("restart_policy",  "unless-stopped"),
        "LOG_VOLUME":      svc.get("log_volume",      "swiftdeploy-logs"),
        "NGINX_IMAGE":     nginx.get("image",         "nginx:latest"),
        "NGINX_PORT":      str(nginx.get("port",      8080)),
        "PROXY_TIMEOUT":   str(nginx.get("proxy_timeout", 30)),
        "OPA_IMAGE":       opa.get("image",           "openpolicyagent/opa:latest-rootless"),
        "OPA_PORT":        str(opa.get("port",        8181)),
        "NETWORK_NAME":    net.get("name",            "swiftdeploy-net"),
        "NETWORK_DRIVER":  net.get("driver_type",     "bridge"),
        "CONTACT":         manifest.get("contact",    "devops@swiftdeploy.local"),
    }


def get_infrastructure_policy(manifest):
    policy = manifest.get("policy", {}).get("infrastructure", {})
    return {
        "min_disk_free_gb": float(policy.get("min_disk_free_gb", 10.0)),
        "max_cpu_load": float(policy.get("max_cpu_load", 2.0)),
        "min_mem_free_percent": float(policy.get("min_mem_free_percent", 10.0)),
    }


def get_canary_policy(manifest):
    policy = manifest.get("policy", {}).get("canary", {})
    return {
        "max_error_rate_percent": float(policy.get("max_error_rate_percent", 1.0)),
        "max_p99_latency_ms": int(policy.get("max_p99_latency_ms", 500)),
        "min_sample_size": int(policy.get("min_sample_size", 10)),
    }

# ══════════════════════════════════════════════════════════════
#  OPA HELPERS
#  All policy decisions go through these functions.
#  The CLI never makes allow/deny decisions itself.
# ══════════════════════════════════════════════════════════════

def get_opa_port():
    manifest = load_manifest()
    return manifest.get("opa", {}).get("port", 8181)


def query_opa(package_path, input_data, data=None):
    """
    Send input_data to OPA and return the decision.

    package_path: e.g. "swiftdeploy/infrastructure"
    input_data:   dict of facts to evaluate
    data:         optional dict to upload into OPA's matching data namespace

    Returns: dict with keys: allow (bool), reasons (list of str)

    Failure modes — each produces a different message:
    - OPA not running       → clear message, does not crash
    - OPA returns bad JSON  → clear message, does not crash
    - Network timeout       → clear message, does not crash
    """
    import urllib.request
    import urllib.error

    opa_port = get_opa_port()

    # If data is provided, load it into OPA's matching data namespace.
    if data is not None:
        namespace = package_path.replace(".", "/").split("/")[-1]
        try:
            data_url = f"http://localhost:{opa_port}/v1/data/{namespace}"
            data_payload = json.dumps(data).encode()
            data_req = urllib.request.Request(
                data_url,
                data=data_payload,
                method="PUT",
                headers={"Content-Type": "application/json"}
            )
            urllib.request.urlopen(data_req, timeout=5)
        except Exception as e:
            return {
                "allow": False,
                "reasons": [f"OPA data upload failed: {e}"],
                "error": "data_upload_failed"
            }

    # Query the policy
    url = f"http://localhost:{opa_port}/v1/data/{package_path.replace('.', '/')}"
    payload = json.dumps({"input": input_data}).encode()

    try:
        req = urllib.request.Request(
            url,
            data=payload,
            method="POST",
            headers={"Content-Type": "application/json"}
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            raw = resp.read()

    except urllib.error.URLError as e:
        if "Connection refused" in str(e) or "refused" in str(e).lower():
            return {
                "allow": False,
                "reasons": ["OPA is not running. Start the stack first: swiftdeploy deploy"],
                "error": "opa_not_running"
            }
        return {
            "allow": False,
            "reasons": [f"OPA network error: {e}"],
            "error": "network_error"
        }
    except Exception as e:
        return {
            "allow": False,
            "reasons": [f"OPA query failed unexpectedly: {e}"],
            "error": "unexpected_error"
        }

    try:
        result   = json.loads(raw)
        opa_data = result.get("result", {})
        allow    = bool(opa_data.get("allow", False))
        reasons  = list(opa_data.get("deny", []))
        if allow and not reasons:
            reasons = ["All checks passed"]
        return {"allow": allow, "reasons": reasons, "error": None}
    except Exception as e:
        return {
            "allow": False,
            "reasons": [f"OPA returned invalid JSON: {e}  raw={raw[:200]}"],
            "error": "bad_response"
        }


def print_opa_decision(domain, decision):
    """Print a formatted OPA decision to the terminal."""
    print(f"\n  {bold('OPA Policy:')} {cyan(domain)}")
    if decision["error"]:
        print(f"  {red('ERROR')}  {decision['reasons'][0]}")
        return

    if decision["allow"]:
        print(f"  {green('ALLOW')}")
        for r in decision["reasons"]:
            ok(r)
    else:
        print(f"  {red('DENY')}")
        for r in decision["reasons"]:
            fail(r)


def get_host_stats():
    """
    Collect host-level resource stats for pre-deploy OPA check.
    Uses only stdlib — no psutil needed.
    """
    import shutil as _shutil

    # Disk free in GB
    usage    = _shutil.disk_usage(BASE_DIR)
    disk_gb  = round(usage.free / (1024 ** 3), 2)

    # CPU load (1-minute average) — os.getloadavg() on Linux/Mac
    # On Windows, getloadavg doesn't exist; we use a subprocess fallback
    try:
        cpu_load = round(os.getloadavg()[0], 2)
    except AttributeError:
        # Windows: use wmic to get CPU load percentage and convert
        try:
            result = subprocess.run(
                ["wmic", "cpu", "get", "loadpercentage", "/value"],
                capture_output=True, text=True, timeout=5
            )
            for line in result.stdout.splitlines():
                if "LoadPercentage" in line:
                    pct = float(line.split("=")[1].strip())
                    # Convert percentage to a load-average-like number
                    # (divide by 100, treat 100% as load of 2.0 for policy purposes)
                    cpu_load = round((pct / 100) * 2.0, 2)
                    break
            else:
                cpu_load = 0.5   # safe default if wmic parse fails
        except Exception:
            cpu_load = 0.5

    # Memory free percent — read from /proc/meminfo on Linux
    # On Windows use wmic
    try:
        with open("/proc/meminfo") as f:
            lines = f.readlines()
        mem = {}
        for line in lines:
            parts = line.split()
            mem[parts[0].rstrip(":")] = int(parts[1])
        mem_free_pct = round(
            (mem.get("MemAvailable", mem.get("MemFree", 1)) / mem["MemTotal"]) * 100, 1
        )
    except Exception:
        try:
            result = subprocess.run(
                ["wmic", "OS", "get", "FreePhysicalMemory,TotalVisibleMemorySize", "/value"],
                capture_output=True, text=True, timeout=5
            )
            vals = {}
            for line in result.stdout.splitlines():
                if "=" in line:
                    k, v = line.strip().split("=", 1)
                    if v.strip():
                        vals[k.strip()] = int(v.strip())
            free  = vals.get("FreePhysicalMemory", 1)
            total = vals.get("TotalVisibleMemorySize", 1)
            mem_free_pct = round((free / total) * 100, 1)
        except Exception:
            mem_free_pct = 50.0   # safe default

    return {
        "disk_free_gb":      disk_gb,
        "cpu_load":          cpu_load,
        "mem_free_percent":  mem_free_pct
    }

# ══════════════════════════════════════════════════════════════
#  METRICS HELPERS
#  Parse Prometheus text format from /metrics endpoint.
#  Used by pre-promote check and status command.
# ══════════════════════════════════════════════════════════════

def scrape_metrics(nginx_port):
    """
    Fetch /metrics from the running app via nginx.
    Returns raw text or None on failure.
    """
    import urllib.request
    url = f"http://localhost:{nginx_port}/metrics"
    try:
        with urllib.request.urlopen(url, timeout=5) as resp:
            return resp.read().decode()
    except Exception as e:
        return None


def parse_prometheus(text):
    """
    Parse Prometheus text format into a dict of metric families.
    Returns: {metric_name: [(labels_dict, value), ...]}
    """
    result = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        # Split off value (and optional timestamp)
        parts = line.rsplit(" ", 1)
        if len(parts) != 2:
            continue
        name_labels, value_str = parts
        try:
            value = float(value_str)
        except ValueError:
            continue

        # Parse labels: metric_name{label="val",...}
        if "{" in name_labels:
            name, rest    = name_labels.split("{", 1)
            labels_str    = rest.rstrip("}")
            labels        = {}
            for kv in labels_str.split(","):
                if "=" in kv:
                    k, v = kv.split("=", 1)
                    labels[k.strip()] = v.strip().strip('"')
        else:
            name   = name_labels
            labels = {}

        result.setdefault(name, []).append((labels, value))
    return result


def calculate_error_rate(parsed):
    """
    Calculate error rate % from http_requests_total.
    error = status_code >= 500
    """
    total  = 0.0
    errors = 0.0
    for labels, value in parsed.get("http_requests_total", []):
        # skip /metrics and /healthz from rate calculation
        if labels.get("path") in ("/metrics", "/healthz"):
            continue
        total += value
        code = labels.get("status_code", "200")
        if code.startswith("5"):
            errors += value
    if total == 0:
        return 0.0, int(total)
    return round((errors / total) * 100, 3), int(total)


def calculate_p99_latency_ms(parsed):
    """
    Calculate P99 latency from http_request_duration_seconds histogram.
    P99 = the bucket boundary where cumulative count >= 99% of total.
    """
    # Collect all histogram buckets across all paths
    buckets = {}
    total_count = 0.0

    for labels, value in parsed.get("http_request_duration_seconds_bucket", []):
        if labels.get("path") in ("/metrics", "/healthz"):
            continue
        le = labels.get("le", "inf")
        buckets[le] = buckets.get(le, 0.0) + value

    if not buckets:
        return 0

    # Get the +Inf bucket = total count
    total_count = buckets.get("+Inf", 0.0)
    if total_count == 0:
        return 0

    target = total_count * 0.99

    # Sort buckets by upper bound, find first bucket that covers 99%
    def sort_key(le):
        return float("inf") if le == "+Inf" else float(le)

    for le in sorted(buckets.keys(), key=sort_key):
        if buckets[le] >= target:
            val = float("inf") if le == "+Inf" else float(le)
            return int(val * 1000)  # convert seconds → ms

    return 0

# ══════════════════════════════════════════════════════════════
def _request_totals(parsed):
    total = 0.0
    errors = 0.0
    for labels, value in parsed.get("http_requests_total", []):
        if labels.get("path") in ("/metrics", "/healthz"):
            continue
        total += value
        if labels.get("status_code", "200").startswith("5"):
            errors += value
    return total, errors


def _histogram_buckets(parsed):
    buckets = {}
    for labels, value in parsed.get("http_request_duration_seconds_bucket", []):
        if labels.get("path") in ("/metrics", "/healthz"):
            continue
        le = labels.get("le", "+Inf")
        buckets[le] = buckets.get(le, 0.0) + value
    return buckets


def calculate_error_rate_window(start_parsed, end_parsed):
    start_total, start_errors = _request_totals(start_parsed)
    end_total, end_errors = _request_totals(end_parsed)
    total = max(0.0, end_total - start_total)
    errors = max(0.0, end_errors - start_errors)
    if total == 0:
        return 0.0, 0
    return round((errors / total) * 100, 3), int(total)


def calculate_p99_latency_window_ms(start_parsed, end_parsed):
    start_buckets = _histogram_buckets(start_parsed)
    end_buckets = _histogram_buckets(end_parsed)
    buckets = {}
    for le in set(start_buckets) | set(end_buckets):
        buckets[le] = max(0.0, end_buckets.get(le, 0.0) - start_buckets.get(le, 0.0))

    total_count = buckets.get("+Inf", 0.0)
    if total_count == 0:
        return 0

    target = total_count * 0.99

    def sort_key(le):
        return float("inf") if le == "+Inf" else float(le)

    for le in sorted(buckets.keys(), key=sort_key):
        if buckets[le] >= target:
            return int((float("inf") if le == "+Inf" else float(le)) * 1000)
    return 0


def scrape_metrics_window(nginx_port, seconds=30):
    first_raw = scrape_metrics(nginx_port)
    if first_raw is None:
        return None
    info(f"Collecting metrics for {seconds}s policy window...")
    time.sleep(seconds)
    second_raw = scrape_metrics(nginx_port)
    if second_raw is None:
        return None

    start = parse_prometheus(first_raw)
    end = parse_prometheus(second_raw)
    error_rate, sample_size = calculate_error_rate_window(start, end)
    p99_ms = calculate_p99_latency_window_ms(start, end)
    return error_rate, p99_ms, sample_size


#  SUBCOMMAND: init
# ══════════════════════════════════════════════════════════════
def cmd_init():
    print(bold("\n[swiftdeploy init]"))
    manifest = load_manifest()
    tvars    = build_vars(manifest)

    for tmpl_path, out_path, label in [
        (NGINX_TMPL,   NGINX_OUT,   "nginx.conf"),
        (COMPOSE_TMPL, COMPOSE_OUT, "docker-compose.yml"),
    ]:
        if not os.path.exists(tmpl_path):
            print(red(f"[ERROR] Template not found: {tmpl_path}"))
            sys.exit(1)
        with open(tmpl_path) as f:
            raw = f.read()
        content = Template(raw).safe_substitute(tvars)
        content = content.replace("$$", "$")
        with open(out_path, "w") as f:
            f.write(content)
        ok(f"Generated {label}  →  {out_path}")

    print(green("\n  init complete.\n"))


# ══════════════════════════════════════════════════════════════
#  SUBCOMMAND: validate
# ══════════════════════════════════════════════════════════════
def cmd_validate():
    print(bold("\n[swiftdeploy validate]"))
    passed = 0
    failed = 0

    print("\n  Check 1: manifest.yaml exists and is valid YAML")
    try:
        manifest = load_manifest()
        ok("manifest.yaml found and parsed successfully")
        passed += 1
    except SystemExit:
        fail("manifest.yaml missing or invalid YAML")
        failed += 1
        manifest = None

    print("\n  Check 2: Required fields present and non-empty")
    if manifest:
        required = {
            "services.image":      manifest.get("services", {}).get("image"),
            "services.port":       manifest.get("services", {}).get("port"),
            "nginx.image":         manifest.get("nginx",    {}).get("image"),
            "nginx.port":          manifest.get("nginx",    {}).get("port"),
            "network.name":        manifest.get("network",  {}).get("name"),
            "network.driver_type": manifest.get("network",  {}).get("driver_type"),
        }
        missing = [k for k, v in required.items() if not v]
        if missing:
            fail(f"Missing fields: {', '.join(missing)}")
            failed += 1
        else:
            ok("All required fields present")
            passed += 1
    else:
        fail("Skipped"); failed += 1

    print("\n  Check 3: Docker image exists locally")
    if manifest:
        image  = manifest.get("services", {}).get("image", "")
        result = subprocess.run(
            ["docker", "image", "inspect", image],
            capture_output=True
        )
        if result.returncode == 0:
            ok(f"Image found: {image}"); passed += 1
        else:
            fail(f"Image NOT found locally: {image}")
            info(f"Build it first:  docker build -t {image} ./app")
            failed += 1
    else:
        fail("Skipped"); failed += 1

    print("\n  Check 4: Nginx port is free on the host")
    if manifest:
        port = int(manifest.get("nginx", {}).get("port", 8080))
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        in_use = sock.connect_ex(("127.0.0.1", port)) == 0
        sock.close()
        if in_use:
            fail(f"Port {port} is already in use"); failed += 1
        else:
            ok(f"Port {port} is free"); passed += 1
    else:
        fail("Skipped"); failed += 1

    print("\n  Check 5: nginx.conf syntax check")
    if not os.path.exists(NGINX_OUT):
        info("nginx.conf not found — running init first...")
        cmd_init()

    import tempfile
    with open(NGINX_OUT) as f:
        raw = f.read()
    test_conf = raw.replace("server service:", "server 127.0.0.1:")
    with tempfile.NamedTemporaryFile(mode="w", suffix=".conf", delete=False) as tmp:
        tmp.write(test_conf)
        tmp_path = tmp.name

    docker_path = tmp_path.replace("\\", "/")
    if len(docker_path) > 1 and docker_path[1] == ":":
        docker_path = "/" + docker_path[0].lower() + docker_path[2:]

    result = subprocess.run(
        ["docker", "run", "--rm",
         "-v", f"{docker_path}:/etc/nginx/conf.d/default.conf:ro",
         "nginx:latest", "nginx", "-t"],
        capture_output=True, text=True
    )
    os.unlink(tmp_path)
    if result.returncode == 0:
        ok("nginx.conf syntax is valid"); passed += 1
    else:
        fail("nginx.conf has syntax errors")
        print(red(result.stderr)); failed += 1

    print()
    print("─" * 44)
    total = passed + failed
    if failed == 0:
        print(green(f"  PASSED {passed}/{total} checks — ready to deploy"))
    else:
        print(red(f"  FAILED {failed}/{total} checks — fix issues first"))
    print("─" * 44 + "\n")
    sys.exit(0 if failed == 0 else 1)


