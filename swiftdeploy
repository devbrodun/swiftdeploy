#  HISTORY HELPER
#  Every significant event gets appended to history.jsonl
# ══════════════════════════════════════════════════════════════
def append_history(record):
    record["timestamp"] = datetime.now(timezone.utc).isoformat()
    with open(HISTORY_FILE, "a") as f:
        f.write(json.dumps(record) + "\n")


# ══════════════════════════════════════════════════════════════
#  SUBCOMMAND: status
#  Live-refreshing terminal dashboard
# ══════════════════════════════════════════════════════════════
def cmd_status():
    print(bold("\n[swiftdeploy status]  (Ctrl+C to exit)\n"))
    manifest   = load_manifest()
    nginx_port = manifest.get("nginx", {}).get("port", 8080)
    opa_port   = manifest.get("opa",   {}).get("port", 8181)

    prev_counts = {}   # for req/s calculation
    prev_time   = None
    prev_chaos  = None

    try:
        while True:
            now       = datetime.now(timezone.utc)
            now_str   = now.strftime("%H:%M:%S")
            raw       = scrape_metrics(nginx_port)

            # Clear screen
            os.system("cls" if os.name == "nt" else "clear")
            print(bold(f"  SwiftDeploy Status  —  {now_str}"))
            print("  " + "─" * 50)

            if raw is None:
                print(red("  Cannot reach /metrics — is the stack running?"))
            else:
                parsed        = parse_prometheus(raw)
                error_rate, n = calculate_error_rate(parsed)
                p99_ms        = calculate_p99_latency_ms(parsed)

                # Calculate req/s since last scrape
                curr_total = sum(
                    v for lbl, v in parsed.get("http_requests_total", [])
                    if lbl.get("path") not in ("/metrics", "/healthz")
                )
                rps = 0.0
                if prev_time is not None:
                    elapsed = (now - prev_time).total_seconds()
                    if elapsed > 0:
                        rps = round((curr_total - prev_counts.get("total", curr_total)) / elapsed, 2)
                prev_counts["total"] = curr_total
                prev_time            = now

                # Get uptime and mode from metrics
                uptime = 0
                for _, v in parsed.get("app_uptime_seconds", []):
                    uptime = int(v)
                mode_val = 0
                for _, v in parsed.get("app_mode", []):
                    mode_val = int(v)
                mode_str = "canary" if mode_val == 1 else "stable"

                chaos_val = 0
                for _, v in parsed.get("chaos_active", []):
                    chaos_val = int(v)
                chaos_str = {0: "none", 1: "slow", 2: "error"}.get(chaos_val, "unknown")

                # Display metrics panel
                print(f"\n  {bold('App Metrics')}")
                print(f"    Mode:          {cyan(mode_str)}")
                print(f"    Uptime:        {uptime}s")
                print(f"    Chaos:         {yellow(chaos_str) if chaos_val else green('none')}")
                print(f"    Req/s:         {rps}")
                print(f"    Error rate:    {'%s%%' % error_rate if error_rate < 1 else red('%s%%' % error_rate)}")
                print(f"    P99 latency:   {'%sms' % p99_ms if p99_ms < 500 else red('%sms' % p99_ms)}")
                print(f"    Total reqs:    {int(curr_total)}")

                # OPA policy compliance
                print(f"\n  {bold('Policy Compliance')}")

                host_stats   = get_host_stats()
                infra_dec    = query_opa("swiftdeploy/infrastructure", host_stats, data=get_infrastructure_policy(manifest))
                canary_input = {"error_rate_percent": error_rate, "p99_latency_ms": p99_ms, "sample_size": n}
                canary_dec   = query_opa("swiftdeploy/canary", canary_input, data=get_canary_policy(manifest))

                infra_symbol  = green("PASS") if infra_dec["allow"]  else red("FAIL")
                canary_symbol = green("PASS") if canary_dec["allow"] else red("FAIL")
                print(f"    infrastructure: [{infra_symbol}]  {infra_dec['reasons'][0]}")
                print(f"    canary:         [{canary_symbol}]  {canary_dec['reasons'][0]}")

                # Append to history
                record = {
                    "event":        "status_scrape",
                    "rps":          rps,
                    "error_rate":   error_rate,
                    "p99_ms":       p99_ms,
                    "mode":         mode_str,
                    "chaos":        chaos_str,
                    "infra_pass":   infra_dec["allow"],
                    "canary_pass":  canary_dec["allow"],
                }
                append_history(record)

                if prev_chaos is not None and chaos_str != prev_chaos:
                    append_history({
                        "event": "chaos_event",
                        "from":  prev_chaos,
                        "to":    chaos_str,
                        "mode":  mode_str,
                    })
                prev_chaos = chaos_str

                # Warn about violations inline
                if not infra_dec["allow"] or not canary_dec["allow"]:
                    print(f"\n  {red('⚠  Policy violations detected — check reasons above')}")

            print(f"\n  {yellow('Refreshing every 5s — Ctrl+C to exit')}")
            time.sleep(5)

    except KeyboardInterrupt:
        print(f"\n\n  {green('Status stopped.')}\n")


# ══════════════════════════════════════════════════════════════
#  SUBCOMMAND: audit
#  Parse history.jsonl → generate audit_report.md
# ══════════════════════════════════════════════════════════════
def cmd_audit():
    print(bold("\n[swiftdeploy audit]"))

    if not os.path.exists(HISTORY_FILE):
        print(red("[ERROR] history.jsonl not found — run 'swiftdeploy status' first to generate history."))
        sys.exit(1)

    records = []
    with open(HISTORY_FILE) as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    continue

    if not records:
        print(red("[ERROR] history.jsonl is empty."))
        sys.exit(1)

    def md_cell(value):
        text = str(value).replace("\r", " ")
        return (text
                .replace("|", "\\|")
                .replace("<", "&lt;")
                .replace(">", "&gt;")
                .replace("\n", "<br>"))

    # ── Build timeline ────────────────────────────────────────
    timeline_rows = []
    violations    = []

    for r in records:
        ts    = r.get("timestamp", "unknown")
        event = r.get("event", "unknown")

        if event == "deploy":
            timeline_rows.append((ts, "Deploy", f"Stack deployed - status: {r.get('status')}"))

        elif event == "promote":
            timeline_rows.append((ts, "Promote", f"Mode switched to **{r.get('mode')}**"))

        elif event == "status_scrape":
            chaos = r.get("chaos", "none")
            if chaos != "none":
                timeline_rows.append((ts, "Chaos", f"Chaos active: `{chaos}` mode"))

        elif event == "chaos_event":
            timeline_rows.append((ts, "Chaos", f"Chaos changed from `{r.get('from')}` to `{r.get('to')}`"))

        elif event == "pre_deploy_check":
            status = "PASS" if r.get("opa_allow") else "FAIL"
            timeline_rows.append((ts, "Pre-Deploy Check", f"Infrastructure policy: **{status}**"))
            if not r.get("opa_allow"):
                for reason in r.get("opa_reasons", []):
                    violations.append((ts, "infrastructure", reason))

        elif event == "pre_promote_check":
            status = "PASS" if r.get("opa_allow") else "FAIL"
            timeline_rows.append((ts, "Pre-Promote Check", f"Canary policy: **{status}**"))
            if not r.get("opa_allow"):
                for reason in r.get("opa_reasons", []):
                    violations.append((ts, "canary", reason))

    # ── Write report ──────────────────────────────────────────
    lines = [
        "# SwiftDeploy Audit Report",
        "",
        f"Generated: {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S UTC')}",
        f"Events processed: {len(records)}",
        "",
        "---",
        "",
        "## Timeline",
        "",
        "| Timestamp | Event | Detail |",
        "|-----------|-------|--------|",
    ]

    for ts, event, detail in timeline_rows:
        # Trim timestamp to readable format
        ts_short = ts[:19].replace("T", " ")
        lines.append(f"| `{md_cell(ts_short)}` | {md_cell(event)} | {md_cell(detail)} |")

    lines += [
        "",
        "---",
        "",
        "## Policy Violations",
        "",
    ]

    if violations:
        lines += [
            "| Timestamp | Policy Domain | Reason |",
            "|-----------|--------------|--------|",
        ]
        for ts, domain, reason in violations:
            ts_short = ts[:19].replace("T", " ")
            lines.append(f"| `{md_cell(ts_short)}` | `{md_cell(domain)}` | {md_cell(reason)} |")
    else:
        lines.append("_No policy violations recorded._")

    lines += [
        "",
        "---",
        "",
        "## Status Scrape Summary",
        "",
    ]

    scrapes = [r for r in records if r.get("event") == "status_scrape"]
    if scrapes:
        avg_rps      = round(sum(r.get("rps", 0) for r in scrapes) / len(scrapes), 2)
        avg_err      = round(sum(r.get("error_rate", 0) for r in scrapes) / len(scrapes), 3)
        avg_p99      = round(sum(r.get("p99_ms", 0) for r in scrapes) / len(scrapes), 1)
        chaos_events = [r for r in scrapes if r.get("chaos") != "none"]
        lines += [
            f"- Total scrapes: **{len(scrapes)}**",
            f"- Average req/s: **{avg_rps}**",
            f"- Average error rate: **{avg_err}%**",
            f"- Average P99 latency: **{avg_p99}ms**",
            f"- Scrapes with chaos active: **{len(chaos_events)}**",
        ]
    else:
        lines.append("_No status scrapes recorded._")

    report = "\n".join(lines) + "\n"
    with open(AUDIT_FILE, "w") as f:
        f.write(report)

    ok(f"Audit report written → {AUDIT_FILE}")
    print(green("\n  audit complete.\n"))


# ══════════════════════════════════════════════════════════════
#  ENTRYPOINT
# ══════════════════════════════════════════════════════════════
def usage():
    print(textwrap.dedent("""
    Usage:
      swiftdeploy init
      swiftdeploy validate
      swiftdeploy deploy
      swiftdeploy promote [canary|stable]
      swiftdeploy teardown [--clean]
      swiftdeploy status
      swiftdeploy audit
    """))


def main():
    args = sys.argv[1:]
    if not args:
        usage(); sys.exit(1)

    cmd = args[0]

    if cmd == "init":           cmd_init()
    elif cmd == "validate":     cmd_validate()
    elif cmd == "deploy":       cmd_deploy()
    elif cmd == "promote":
        if len(args) < 2:
            print(red("[ERROR] promote requires: canary or stable"))
            sys.exit(1)
        cmd_promote(args[1])
    elif cmd == "teardown":     cmd_teardown(clean="--clean" in args)
    elif cmd == "status":       cmd_status()
    elif cmd == "audit":        cmd_audit()
    else:
        print(red(f"[ERROR] Unknown subcommand: '{cmd}'"))
        usage(); sys.exit(1)


if __name__ == "__main__":
    main()
