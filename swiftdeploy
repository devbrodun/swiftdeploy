#  SUBCOMMAND: deploy  (now gated by OPA pre-deploy check)
# ══════════════════════════════════════════════════════════════
def wait_for_opa(opa_port, timeout=45):
    """
    Poll OPA health endpoint until it responds or timeout.
    OPA must be running before we can query policies.
    Catches ALL exceptions including socket timeouts so we never crash here.
    """
    import urllib.request
    import urllib.error
    import socket as _socket

    url = f"http://localhost:{opa_port}/health"
    info(f"Waiting for OPA to be ready at port {opa_port}...")

    for i in range(timeout):
        try:
            req = urllib.request.Request(url)
            with urllib.request.urlopen(req, timeout=3) as resp:
                if resp.status == 200:
                    ok(f"OPA is ready ({i+1}s)")
                    return True
        except urllib.error.HTTPError as e:
            # OPA returned an HTTP error — it is at least running
            if e.code < 500:
                ok(f"OPA is ready ({i+1}s)")
                return True
        except (urllib.error.URLError, _socket.timeout,
                ConnectionRefusedError, OSError, TimeoutError):
            # Not ready yet — keep waiting silently
            pass
        except KeyboardInterrupt:
            raise   # let Ctrl+C through
        except Exception:
            pass    # swallow anything else — we just keep polling

        time.sleep(1)

    return False


def cmd_deploy():
    print(bold("\n[swiftdeploy deploy]"))

    manifest = load_manifest()
    policy_data = get_infrastructure_policy(manifest)

    # ── Step 1: start the stack so OPA is available ───────────
    cmd_init()
    info("Starting OPA policy sidecar...")
    result = subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "up", "-d", "opa"],
        cwd=BASE_DIR
    )
    if result.returncode != 0:
        print(red("[ERROR] Could not start OPA policy sidecar. Pre-deploy policy could not be evaluated."))
        sys.exit(1)

    # ── Step 2: wait for OPA to be healthy ────────────────────
    opa_port  = manifest.get("opa", {}).get("port", 8181)
    opa_ready = wait_for_opa(opa_port, timeout=30)
    if not opa_ready:
        print(red("[ERROR] OPA did not start in time. Check: docker compose logs opa"))
        sys.exit(1)

    # ── Step 3: OPA pre-deploy gate ───────────────────────────
    print(bold("\n  Running pre-deploy policy checks through OPA..."))
    host_stats = get_host_stats()
    info(f"Host stats -> disk={host_stats['disk_free_gb']}GB free  "
         f"cpu_load={host_stats['cpu_load']}  "
         f"mem_free={host_stats['mem_free_percent']}%")

    decision  = query_opa(
        "swiftdeploy/infrastructure",
        host_stats,
        data=policy_data
    )
    print_opa_decision("infrastructure", decision)

    append_history({
        "event":       "pre_deploy_check",
        "host_stats":  host_stats,
        "opa_allow":   decision["allow"],
        "opa_reasons": decision["reasons"]
    })

    if not decision["allow"]:
        print(red("\n  [BLOCKED] Pre-deploy policy check failed — tearing down.\n"))
        subprocess.run(
            ["docker", "compose", "-f", COMPOSE_OUT, "down", "-v", "--remove-orphans"],
            cwd=BASE_DIR
        )
        sys.exit(1)

    info("Starting application stack with docker compose...")
    result = subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "up", "-d", "--remove-orphans"],
        cwd=BASE_DIR
    )
    if result.returncode != 0:
        print(red("[ERROR] docker compose up failed."))
        sys.exit(1)

    nginx_port = manifest.get("nginx", {}).get("port", 8080)
    health_url = f"http://localhost:{nginx_port}/healthz"
    timeout    = 60
    interval   = 3
    elapsed    = 0
    info(f"Waiting for health check at {health_url}  (timeout: {timeout}s) ...")

    import urllib.request
    while elapsed < timeout:
        try:
            with urllib.request.urlopen(health_url, timeout=3) as resp:
                if resp.status == 200:
                    ok(f"Stack is healthy! ({elapsed}s)")
                    append_history({"event": "deploy", "status": "success"})
                    print(green("\n  deploy complete — stack is running.\n"))
                    return
        except Exception:
            pass
        time.sleep(interval)
        elapsed += interval
        info(f"  ... {elapsed}s elapsed")

    print(red(f"\n[ERROR] Health check did not pass within {timeout}s."))
    print(yellow("\n  -- nginx logs ------------------------------------------"))
    subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "logs", "--tail=30", "nginx"],
        cwd=BASE_DIR
    )
    print(yellow("\n  -- service logs ----------------------------------------"))
    subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "logs", "--tail=30", "service"],
        cwd=BASE_DIR
    )
    sys.exit(1)


# ══════════════════════════════════════════════════════════════
#  SUBCOMMAND: promote  (now gated by OPA canary check)
# ══════════════════════════════════════════════════════════════
def cmd_promote(target_mode):
    if target_mode not in ("canary", "stable"):
        print(red(f"[ERROR] promote requires 'canary' or 'stable', got: '{target_mode}'"))
        sys.exit(1)

    print(bold(f"\n[swiftdeploy promote → {target_mode}]"))

    # Canary safety check only needed when promoting TO canary
    if target_mode == "canary":
        print(bold("\n  Running pre-promote policy checks..."))
        manifest   = load_manifest()
        nginx_port = manifest.get("nginx", {}).get("port", 8080)
        window     = scrape_metrics_window(nginx_port, seconds=30)

        if window is None:
            print(red("[ERROR] Could not scrape /metrics — is the stack running?"))
            sys.exit(1)

        error_rate, p99_ms, n = window

        metrics_input = {
            "error_rate_percent": error_rate,
            "p99_latency_ms":     p99_ms,
            "sample_size":        n
        }
        info(f"Metrics → error_rate={error_rate}%  p99={p99_ms}ms  samples={n}")

        decision  = query_opa(
            "swiftdeploy/canary",
            metrics_input,
            data=get_canary_policy(manifest)
        )
        print_opa_decision("canary", decision)

        append_history({
            "event":       "pre_promote_check",
            "target_mode": target_mode,
            "metrics":     metrics_input,
            "opa_allow":   decision["allow"],
            "opa_reasons": decision["reasons"]
        })

        if not decision["allow"]:
            print(red("\n  [BLOCKED] Canary policy check failed. Fix issues above.\n"))
            sys.exit(1)

    # ── update manifest mode in-place ────────────────────────
    with open(MANIFEST_PATH, "r") as f:
        lines = f.readlines()
    new_lines = []
    replaced  = False
    for line in lines:
        stripped = line.lstrip()
        if stripped.startswith("mode:") and not replaced:
            indent = line[: len(line) - len(stripped)]
            new_lines.append(f"{indent}mode: {target_mode}\n")
            replaced = True
        else:
            new_lines.append(line)
    if not replaced:
        new_lines.append(f"  mode: {target_mode}\n")
    with open(MANIFEST_PATH, "w") as f:
        f.writelines(new_lines)
    ok(f"manifest.yaml → mode set to '{target_mode}'")

    cmd_init()

    info("Restarting service container...")
    result = subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "restart", "service"],
        cwd=BASE_DIR
    )
    if result.returncode != 0:
        print(red("[ERROR] Failed to restart service container."))
        sys.exit(1)
    ok("Service container restarted")

    manifest   = load_manifest()
    nginx_port = manifest.get("nginx", {}).get("port", 8080)
    health_url = f"http://localhost:{nginx_port}/healthz"
    info(f"Confirming mode via {health_url} ...")
    time.sleep(4)

    import urllib.request as _ur
    import json as _json
    for attempt in range(10):
        try:
            with _ur.urlopen(health_url, timeout=5) as resp:
                body   = _json.loads(resp.read())
                x_mode = resp.headers.get("X-Mode", "stable")
                uptime = body.get("uptime_seconds", "?")
                ok(f"/healthz → status={body.get('status')}  uptime={uptime}s  X-Mode={x_mode}")
                append_history({"event": "promote", "mode": target_mode, "status": "success"})
                print(green(f"\n  promote complete — now running in '{target_mode}' mode.\n"))
                return
        except Exception as e:
            info(f"  attempt {attempt + 1}/10 — waiting... ({e})")
            time.sleep(3)

    print(red("[ERROR] Could not confirm new mode via /healthz"))
    sys.exit(1)


# ══════════════════════════════════════════════════════════════
#  SUBCOMMAND: teardown
# ══════════════════════════════════════════════════════════════
def cmd_teardown(clean=False):
    print(bold("\n[swiftdeploy teardown]"))
    if not os.path.exists(COMPOSE_OUT):
        info("docker-compose.yml not found — nothing to tear down.")
    else:
        info("Stopping and removing containers, networks, volumes...")
        result = subprocess.run(
            ["docker", "compose", "-f", COMPOSE_OUT, "down", "-v", "--remove-orphans"],
            cwd=BASE_DIR
        )
        if result.returncode == 0:
            ok("Stack torn down successfully")
        else:
            print(red("[ERROR] docker compose down failed"))
            sys.exit(1)
    if clean:
        info("--clean flag set — removing generated config files...")
        for path, label in [(NGINX_OUT, "nginx.conf"), (COMPOSE_OUT, "docker-compose.yml")]:
            if os.path.exists(path):
                os.remove(path)
                ok(f"Deleted {label}")
    print(green("\n  teardown complete.\n"))

